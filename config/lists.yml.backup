        trusted: true
        update_frequency: daily
      - url: "https://ransomwaretracker.abuse.ch/downloads/RW_DOMBL.txt"
        format: domains
        trusted: false  # Requires review due to sensitivity
        update_frequency: dailyquency: daily
  
  fortnite:
    description: "Fortnite-related domains"
    category: gaming
    status: stable
  
  fraud:
    description: "Fraud and scam domains"
    category: security
    status: stable
  
  gambling:
    description: "Gambling sites"
    category: content
    status: stable
  
  malware:
