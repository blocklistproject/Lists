        format: hosts
        trusted: true
        update_frequency: weekly
        # Note: Large list, may need sampling or incremental updatesquency: dailyquency: daily
      - url: "https://raw.githubusercontent.com/Spam404/lists/master/main-blacklist.txt"
        format: domains
        trusted: true
        update_frequency: daily
      - url: "https://malware-filter.gitlab.io/malware-filter/urlhaus-filter-hosts.txt"
        format: hosts
        trusted: true
        update_fre
    upstream_sources:
      - url: "https://raw.githubusercontent.com/Casualtek/Ransomware-IP-Domain/master/Domain.txt"
